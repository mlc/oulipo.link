{
  "compilerOptions": {
    "target": "ES2018",
    "moduleResolution": "bundler",
    "allowJs": true,
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "importHelpers": true,
    "lib": ["dom", "ES2018"]
  },
  "include": ["src", "webpack.config.ts"],
  "exclude": ["node_modules"]
}
